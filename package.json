{
  "name": "copy-of-recoverx-technologies",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "react-snap || echo 'Pre-rendering failed, but continuing build...'",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "reactSnap": {
    "source": "build",
    "minifyHtml": {
      "collapseWhitespace": false
    },
    "skipThirdPartyRequests": true,
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox",
      "--disable-gpu",
      "--disable-dev-shm-usage"
    ],
    "routes": [
      "/",
      "/about",
      "/services",
      "/blog",
      "/blog/industrial-scrap-management-bangalore",
      "/blog/e-waste-recycling-startups-india",
      "/greencycle",
      "/contact"
    ]
  },
  "dependencies": {
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "react-snap": "^1.23.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
